{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "required": ["schema_version", "generated_utc", "student", "lab", "artifacts_sha256", "validation"],
    "properties": {
      "schema_version": { "type": "string", "const": "3.1" },
      "generated_utc": { "type": "string" },
  
      "student": {
        "type": "object",
        "required": ["token", "token_hash8", "name", "group"],
        "properties": {
          "token": { "type": "string", "minLength": 10 },
          "token_hash8": { "type": "string", "pattern": "^[a-f0-9]{8}$" },
          "name": { "type": "string", "minLength": 3 },
          "group": { "type": "string", "minLength": 2 }
        }
      },
  
      "lab": {
        "type": "object",
        "required": ["apihost", "must_use"],
        "properties": {
          "apihost": { "type": "string" },
          "must_use": {
            "type": "object",
            "required": ["login_endpoint", "books_endpoint", "api_key_header"],
            "properties": {
              "login_endpoint": { "type": "string" },
              "books_endpoint": { "type": "string" },
              "api_key_header": { "type": "string", "const": "X-API-KEY" }
            }
          }
        }
      },
  
      "artifacts_sha256": {
        "type": "object",
        "required": [
          "books_before",
          "books_sorted_isbn",
          "mybook_post",
          "books_by_me",
          "add100_report",
          "postman_collection",
          "postman_environment",
          "curl_get_books",
          "curl_get_books_isbn",
          "curl_get_books_sorted"
        ],
        "properties": {
          "books_before": { "type": "string" },
          "books_sorted_isbn": { "type": "string" },
          "mybook_post": { "type": "string" },
          "books_by_me": { "type": "string" },
          "add100_report": { "type": "string" },
          "postman_collection": { "type": "string" },
          "postman_environment": { "type": "string" },
          "curl_get_books": { "type": "string" },
          "curl_get_books_isbn": { "type": "string" },
          "curl_get_books_sorted": { "type": "string" }
        }
      },
  
      "validation": {
        "type": "object",
        "required": ["must_have_mybook_title_contains_token_hash8", "must_have_added_100"],
        "properties": {
          "must_have_mybook_title_contains_token_hash8": { "type": "boolean", "const": true },
          "must_have_added_100": { "type": "boolean", "const": true }
        }
      }
    }
  }